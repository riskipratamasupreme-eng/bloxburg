local fpsValues = {}
local currentFPS = 60

AddConn("MasterRender", RunService.RenderStepped:Connect(function(dt)
    -- FIXED FPS: Use delta time array for accurate calculation
    table.insert(fpsValues, dt)
    if #fpsValues > 60 then
        table.remove(fpsValues, 1)
    end

    -- Calculate average FPS from last 60 frames
    local totalDT = 0
    for _, v in ipairs(fpsValues) do
        totalDT = totalDT + v
    end
    currentFPS = math.floor(#fpsValues / totalDT)

    -- Watermark update
    pcall(function()
        local ping = 0
        pcall(function()
            ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        end)
        local t = os.date("%H:%M:%S")
        WMText.Text = string.format("☢️ KimJong v3.1 | FPS: %d | Ping: %dms | %s | 🛡️SHIELD ON", currentFPS, ping, t)
    end)

    -- Shield pulse
    pcall(function()
        local pulse = math.abs(math.sin(tick() * 2))
        SIText.TextColor3 = Color3.fromRGB(0, math.floor(150 + 105 * pulse), 0)
    end)
end))

