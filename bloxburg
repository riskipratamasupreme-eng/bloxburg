                end
                
                -- Block Remove on LocalPlayer
                if method == "Remove" and self == LocalPlayer then
                    warn("[KimJong Shield] ⛔ REMOVE PLAYER BLOCKED!")
                    return
                end
                
                return oldNamecall(self, ...)
            end)
            setreadonly(mt, true)
            AntiDetect.OriginalFunctions.Namecall = oldNamecall
        end
    end)
end

