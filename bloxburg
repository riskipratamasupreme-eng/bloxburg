local function SetupAntiKick()
    -- Method 1: Hook LocalPlayer.Kick
    pcall(function()
        local oldKick = LocalPlayer.Kick
        if hookfunction then
            AntiDetect.OriginalFunctions.Kick = hookfunction(LocalPlayer.Kick, function(self, ...)
                if self == LocalPlayer then
                    warn("[KimJong Shield] ⛔ KICK BLOCKED!")
                    return -- Block the kick
                end
                return AntiDetect.OriginalFunctions.Kick(self, ...)
            end)
        end
    end)

    -- Method 2: Hook Players:FindFirstChild to hide detection
    pcall(function()
        if hookfunction then
            local oldFF = game.FindFirstChild
            AntiDetect.OriginalFunctions.FindFirstChild = hookfunction(game.FindFirstChild, function(self, name, ...)
                -- Block anti-cheat script lookups
                if type(name) == "string" then
                    local lower = name:lower()
                    if lower:find("anticheat") or lower:find("anti_cheat") or 
                       lower:find("ac_") or lower:find("detect") or 
                       lower:find("exploit") or lower:find("cheatdetect") or
                       lower:find("securitycheck") or lower:find("validation") then
                        -- Return nil to hide anti-cheat scripts from themselves
                    end
                end
                return AntiDetect.OriginalFunctions.FindFirstChild(self, name, ...)
            end)
        end
    end)

    -- Method 3: Intercept TeleportService kicks
    pcall(function()
        if hookfunction then
            local oldTeleport = TeleportService.Teleport
            AntiDetect.OriginalFunctions.Teleport = hookfunction(TeleportService.Teleport, function(self, placeId, ...)
                -- Check if this is a kick disguised as teleport
                if placeId == 0 or placeId == nil then
                    warn("[KimJong Shield] ⛔ TELEPORT KICK BLOCKED!")
                    return
                end
                -- Check if teleporting to a ban/kick place
                local args = {...}
                local teleportData = args[2]
                if type(teleportData) == "table" then
                    if teleportData.kicked or teleportData.banned or teleportData.reason then
                        warn("[KimJong Shield] ⛔ BAN TELEPORT BLOCKED!")
                        return
                    end
                end
                return AntiDetect.OriginalFunctions.Teleport(self, placeId, ...)
            end)
        end
    end)

    -- Method 4: Block :Kick() on the player instance
    pcall(function()
        local mt = getrawmetatable(game)
        if mt and setreadonly then
            local oldNamecall = mt.__namecall
            setreadonly(mt, false)
            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                
                -- Block Kick
                if method == "Kick" and self == LocalPlayer then
                    warn("[KimJong Shield] ⛔ __namecall KICK BLOCKED!")
                    return
                end
                
                -- Block Destroy on LocalPlayer
                if method == "Destroy" and self == LocalPlayer then
                    warn("[KimJong Shield] ⛔ DESTROY PLAYER BLOCKED!")
