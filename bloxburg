local function Slider(parent, text, min, max, default, callback, order)
    local value = default or min

    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 38)
    f.BackgroundColor3 = CurrentTheme.BackgroundAlt
    f.BorderSizePixel = 0
    f.LayoutOrder = order or 0
    f.ZIndex = 13
    f.Parent = parent
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)

    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1, -55, 0, 16)
    l.Position = UDim2.new(0, 8, 0, 2)
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextSize = 10
    l.Font = Enum.Font.Gotham
    l.TextColor3 = CurrentTheme.Text
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.ZIndex = 14
    l.Parent = f

    local vl = Instance.new("TextLabel")
    vl.Size = UDim2.new(0, 45, 0, 16)
    vl.Position = UDim2.new(1, -50, 0, 2)
    vl.BackgroundTransparency = 1
    vl.Text = tostring(math.floor(value))
    vl.TextSize = 10
    vl.Font = Enum.Font.GothamBold
    vl.TextColor3 = CurrentTheme.Secondary
    vl.TextXAlignment = Enum.TextXAlignment.Right
    vl.ZIndex = 14
    vl.Parent = f

    local sbg = Instance.new("Frame")
    sbg.Size = UDim2.new(1, -16, 0, 4)
    sbg.Position = UDim2.new(0, 8, 0, 26)
    sbg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    sbg.BorderSizePixel = 0
    sbg.ZIndex = 15
    sbg.Parent = f
    Instance.new("UICorner", sbg).CornerRadius = UDim.new(1, 0)

    local pct = math.clamp((value - min) / (max - min), 0, 1)
    local sf = Instance.new("Frame")
    sf.Size = UDim2.new(pct, 0, 1, 0)
    sf.BackgroundColor3 = CurrentTheme.Primary
    sf.BorderSizePixel = 0
    sf.ZIndex = 16
    sf.Parent = sbg
    Instance.new("UICorner", sf).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new(pct, -6, 0.5, -6)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.BorderSizePixel = 0
    knob.ZIndex = 17
    knob.Parent = sbg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local sliding = false
    local function update(pos)
        local rel = math.clamp((pos.X - sbg.AbsolutePosition.X) / sbg.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max - min) * rel)
        vl.Text = tostring(value)
        sf.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -6, 0.5, -6)
        pcall(callback, value)
    end

    sbg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true; update(i.Position) end
    end)
    knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then update(i.Position) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
    end)

    return f
end

