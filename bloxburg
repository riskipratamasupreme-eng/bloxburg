-- ESP using BillboardGui for Name, Distance, Health
local function SetupBillboardESP()
    AddConnection("ESPUpdate", RunService.RenderStepped:Connect(function()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                pcall(function()
                    local char = player.Character
                    local head = char:FindFirstChild("Head")
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    local myHRP = GetRootPart()

                    if not head or not hum or not hrp or not myHRP then return end

                    local dist = math.floor((hrp.Position - myHRP.Position).Magnitude)
                    if dist > States.ESPMaxDist then
                        local bb = head:FindFirstChild("KJ_ESP_BB")
                        if bb then bb.Enabled = false end
                        return
                    end

                    local bb = head:FindFirstChild("KJ_ESP_BB")
                    if not bb then
                        bb = Instance.new("BillboardGui")
                        bb.Name = "KJ_ESP_BB"
                        bb.Size = UDim2.new(0, 200, 0, 60)
                        bb.StudsOffset = Vector3.new(0, 3, 0)
                        bb.AlwaysOnTop = true
                        bb.Parent = head

                        local nameL = Instance.new("TextLabel")
                        nameL.Name = "NameLabel"
                        nameL.Size = UDim2.new(1, 0, 0, 15)
                        nameL.BackgroundTransparency = 1
                        nameL.Font = Enum.Font.GothamBold
                        nameL.TextSize = 13
                        nameL.TextColor3 = States.ESPColor
                        nameL.TextStrokeTransparency = 0.5
                        nameL.TextStrokeColor3 = Color3.new(0, 0, 0)
                        nameL.Parent = bb

                        local distL = Instance.new("TextLabel")
                        distL.Name = "DistLabel"
                        distL.Size = UDim2.new(1, 0, 0, 12)
                        distL.Position = UDim2.new(0, 0, 0, 15)
                        distL.BackgroundTransparency = 1
                        distL.Font = Enum.Font.Gotham
                        distL.TextSize = 11
                        distL.TextColor3 = Color3.new(1, 1, 1)
                        distL.TextStrokeTransparency = 0.5
                        distL.TextStrokeColor3 = Color3.new(0, 0, 0)
                        distL.Parent = bb

                        local healthBG = Instance.new("Frame")
                        healthBG.Name = "HealthBG"
                        healthBG.Size = UDim2.new(0.8, 0, 0, 4)
                        healthBG.Position = UDim2.new(0.1, 0, 0, 30)
                        healthBG.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                        healthBG.BorderSizePixel = 0
                        healthBG.Parent = bb

                        local healthFill = Instance.new("Frame")
                        healthFill.Name = "HealthFill"
                        healthFill.Size = UDim2.new(1, 0, 1, 0)
                        healthFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                        healthFill.BorderSizePixel = 0
                        healthFill.Parent = healthBG

                        local hCorner = Instance.new("UICorner")
                        hCorner.CornerRadius = UDim.new(1, 0)
                        hCorner.Parent = healthBG
                        local hfCorner = Instance.new("UICorner")
                        hfCorner.CornerRadius = UDim.new(1, 0)
                        hfCorner.Parent = healthFill
                    end

                    bb.Enabled = States.NameESP or States.DistanceESP or States.HealthESP

                    local nameL = bb:FindFirstChild("NameLabel")
                    local distL = bb:FindFirstChild("DistLabel")
                    local healthBG = bb:FindFirstChild("HealthBG")

                    if nameL then
                        nameL.Visible = States.NameESP
                        nameL.Text = player.DisplayName .. " (@" .. player.Name .. ")"
                        nameL.TextColor3 = States.ESPColor
                    end

                    if distL then
                        distL.Visible = States.DistanceESP
                        distL.Text = "[" .. dist .. " studs]"
                    end

                    if healthBG then
                        healthBG.Visible = States.HealthESP
                        local fill = healthBG:FindFirstChild("HealthFill")
                        if fill then
                            local hp = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                            fill.Size = UDim2.new(hp, 0, 1, 0)
                            fill.BackgroundColor3 = Color3.fromRGB(255 * (1 - hp), 255 * hp, 0)
                        end
                    end
                end)
            end
        end
    end))
end

