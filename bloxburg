-- 🛡️ LAYER 5: ANTI-CHEAT SCRIPT NEUTRALIZER
-- Find and disable anti-cheat LocalScripts
-- ═══════════════════════════════════════

local function NeutralizeAntiCheatScripts()
    pcall(function()
        local neutralized = 0
        
        local function ProcessScript(script)
            if script:IsA("LocalScript") or script:IsA("ModuleScript") then
                local name = script.Name:lower()
                if name:find("anticheat") or name:find("anti_cheat") or 
                   name:find("ac_") or name:find("cheatdetect") or
                   name:find("exploitdetect") or name:find("securitycheck") or
                   name:find("hackdetect") or name:find("speedcheck") or
                   name:find("flydetect") or name:find("noclipdetect") or
                   name:find("validation") or name:find("integrity") or
                   name:find("guardian") or name:find("sentinel") or
                   name:find("watchdog") or name:find("monitor") then
                    pcall(function()
                        script.Disabled = true
                        neutralized = neutralized + 1
                    end)
                end
            end
        end
        
        -- Scan all script containers
        local containers = {
            LocalPlayer:FindFirstChild("PlayerScripts"),
            LocalPlayer:FindFirstChild("PlayerGui"),
            LocalPlayer.Character,
        }
        
        for _, container in pairs(containers) do
            if container then
                for _, desc in pairs(container:GetDescendants()) do
                    ProcessScript(desc)
                end
            end
        end
        
        -- Also check ReplicatedFirst
        pcall(function()
            for _, desc in pairs(game:GetService("ReplicatedFirst"):GetDescendants()) do
                ProcessScript(desc)
            end
        end)
        
        if neutralized > 0 then
            warn("[KimJong Shield] 🛡️ Neutralized " .. neutralized .. " anti-cheat scripts!")
        end
    end)
end

pcall(NeutralizeAntiCheatScripts)

