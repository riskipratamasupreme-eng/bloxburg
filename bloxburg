                        desc.TextTransparency = 0
                    end
                    if desc:IsA("Frame") or desc:IsA("ScrollingFrame") or desc:IsA("TextButton") then
                        if not desc:GetAttribute("KeepTransparent") then
                            desc.BackgroundTransparency = desc:GetAttribute("OrigTransparency") or 0
                        end
                    end
                end)
            end
        else
            MainFrame.Visible = false
        end
    end
end))

