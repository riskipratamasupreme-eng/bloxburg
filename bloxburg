                            hf.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                            hf.BorderSizePixel = 0
                            hf.Parent = hbg
                            Instance.new("UICorner", hf).CornerRadius = UDim.new(1, 0)
                        end

                        bb.Enabled = true
                        local nl = bb:FindFirstChild("N")
                        local dl = bb:FindFirstChild("D")
                        local hbg = bb:FindFirstChild("HBG")

                        if nl then nl.Text = p.DisplayName .. " (@" .. p.Name .. ")" end
