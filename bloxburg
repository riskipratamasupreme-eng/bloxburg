-- 🛡️ LAYER 3: METAMETHOD HOOK SHIELD
-- Hook __index, __newindex, __namecall
-- Spoof all suspicious property reads
-- ═══════════════════════════════════════

local function SetupMetamethodHooks()
    pcall(function()
        local mt = getrawmetatable(game)
        if not mt then return end
        if not setreadonly then return end
        
        local oldIndex = mt.__index
        local oldNewindex = mt.__newindex
        local oldNamecall = rawget(mt, "__namecall") or mt.__namecall
        
        setreadonly(mt, false)
        
        -- ═══ __index HOOK ═══
        -- Intercept property reads to spoof values
        mt.__index = newcclosure(function(self, key)
            -- Spoof Humanoid properties
            if AntiDetect.Active then
                pcall(function()
                    if typeof(self) == "Instance" and self:IsA("Humanoid") then
                        local char = LocalPlayer.Character
                        if char and self:IsDescendantOf(char) then
                            -- Spoof WalkSpeed - return normal value to anti-cheat
                            if key == "WalkSpeed" and AntiDetect.SpoofWalkSpeed then
                                -- Anti-cheat reads WalkSpeed → we return 16 (normal)
                                -- But actual WalkSpeed is our modified value
                                local realVal = oldIndex(self, key)
                                if realVal > 16 then
                                    return 16 -- Spoof to normal
                                end
                            end
                            
                            -- Spoof JumpPower
                            if key == "JumpPower" and AntiDetect.SpoofJumpPower then
                                local realVal = oldIndex(self, key)
                                if realVal > 50 then
                                    return 50 -- Spoof to normal
                                end
                            end
                            
                            -- Spoof JumpHeight
                            if key == "JumpHeight" then
                                return 7.2 -- Default
                            end
                        end
                    end
                    
                    -- Hide HumanoidRootPart velocity from detection
                    if typeof(self) == "Instance" and self:IsA("BasePart") then
                        if self.Name == "HumanoidRootPart" then
                            local char = LocalPlayer.Character
                            if char and self:IsDescendantOf(char) then
                                if key == "Velocity" then
                                    local vel = oldIndex(self, key)
                                    if vel.Magnitude > 100 then
                                        return Vector3.new(0, 0, 0) -- Spoof high velocity
                                    end
                                end
                                -- Hide BodyMovers from detection
                                if key == "AssemblyLinearVelocity" then
                                    local vel = oldIndex(self, key)
                                    if vel.Magnitude > 100 then
                                        return Vector3.new(0, 0, 0)
                                    end
                                end
                            end
                        end
                    end
                end)
            end
            
            return oldIndex(self, key)
        end)
        
        -- ═══ __newindex HOOK ═══
        -- Intercept property writes to detect anti-cheat resets
        mt.__newindex = newcclosure(function(self, key, value)
            if AntiDetect.Active then
                pcall(function()
                    if typeof(self) == "Instance" and self:IsA("Humanoid") then
                        local char = LocalPlayer.Character
                        if char and self:IsDescendantOf(char) then
                            -- Prevent anti-cheat from resetting WalkSpeed
                            if key == "WalkSpeed" and AntiDetect.SpoofWalkSpeed then
                                if _G.KimJongStates and _G.KimJongStates.WalkSpeed then
                                    if value == 16 and _G.KimJongStates.WalkSpeed > 16 then
                                        -- Anti-cheat trying to reset! Block it
                                        return oldNewindex(self, key, _G.KimJongStates.WalkSpeed)
                                    end
                                end
                            end
                            
                            -- Prevent anti-cheat from resetting JumpPower
                            if key == "JumpPower" and AntiDetect.SpoofJumpPower then
                                if _G.KimJongStates and _G.KimJongStates.JumpPower then
                                    if value == 50 and _G.KimJongStates.JumpPower > 50 then
                                        return oldNewindex(self, key, _G.KimJongStates.JumpPower)
                                    end
                                end
                            end
                            
                            -- Block Health = 0 from anti-cheat (kill attempt)
                            if key == "Health" and value == 0 then
                                -- Check if it's from anti-cheat, not from us
                                -- Allow if we're resetting character
                                if not _G.KimJongResetting then
                                    warn("[KimJong Shield] ⛔ HEALTH KILL BLOCKED!")
                                    return
                                end
                            end
                        end
                    end
                end)
            end
            
            return oldNewindex(self, key, value)
        end)
        
        -- ═══ __namecall HOOK (ENHANCED) ═══
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            if AntiDetect.Active then
                -- ══ BLOCK KICKS ══
                if method == "Kick" then
                    if self == LocalPlayer or (typeof(self) == "Instance" and self:IsA("Player")) then
                        if self == LocalPlayer then
                            warn("[KimJong Shield] ⛔ NAMECALL KICK BLOCKED! Method: " .. method)
                            return
                        end
                    end
                end
                
                -- ══ BLOCK DESTROY ON PLAYER/CHARACTER ══
                if method == "Destroy" or method == "Remove" then
                    if self == LocalPlayer then
                        warn("[KimJong Shield] ⛔ PLAYER DESTROY BLOCKED!")
                        return
                    end
                    local char = LocalPlayer.Character
                    if char and self == char then
                        if not _G.KimJongResetting then
                            warn("[KimJong Shield] ⛔ CHARACTER DESTROY BLOCKED!")
                            return
                        end
                    end
                end
                
                -- ══ INTERCEPT REMOTE EVENTS ══
                if method == "FireServer" and typeof(self) == "Instance" and self:IsA("RemoteEvent") then
                    local remoteName = self.Name:lower()
                    
                    -- Block anti-cheat report remotes
                    if remoteName:find("report") or remoteName:find("detect") or 
                       remoteName:find("anticheat") or remoteName:find("exploit") or
                       remoteName:find("violation") or remoteName:find("flag") or
                       remoteName:find("security") or remoteName:find("ban") or
                       remoteName:find("kick") or remoteName:find("cheat") or
                       remoteName:find("hack") or remoteName:find("suspicious") or
                       remoteName:find("verify") or remoteName:find("validate") or
                       remoteName:find("integrity") or remoteName:find("ac_") or
                       remoteName:find("check") or remoteName:find("monitor") then
                        warn("[KimJong Shield] ⛔ ANTI-CHEAT REMOTE BLOCKED: " .. self.Name)
                        return
                    end
                    
                    -- Spoof player data in remote arguments
                    for i, arg in pairs(args) do
                        if type(arg) == "table" then
                            -- Remove suspicious data from tables
                            if arg.speed or arg.walkspeed or arg.WalkSpeed then
                                arg.speed = 16
                                arg.walkspeed = 16
                                arg.WalkSpeed = 16
                            end
                            if arg.jumppower or arg.JumpPower then
                                arg.jumppower = 50
                                arg.JumpPower = 50
                            end
                            if arg.position and typeof(arg.position) == "Vector3" then
                                -- Don't spoof position in remotes (breaks game)
                            end
                            if arg.exploit or arg.cheat or arg.hack then
                                arg.exploit = nil
                                arg.cheat = nil
                                arg.hack = nil
                            end
                        end
                        -- Spoof number values that look like speed/jump
                        if type(arg) == "number" then
                            -- If sending walkspeed value
                            if arg > 50 and arg == (_G.KimJongStates and _G.KimJongStates.WalkSpeed or 16) then
                                args[i] = 16
                            end
                        end
                    end
                end
                
                -- ══ INTERCEPT REMOTE FUNCTIONS ══
                if method == "InvokeServer" and typeof(self) == "Instance" and self:IsA("RemoteFunction") then
                    local remoteName = self.Name:lower()
                    
                    -- Block anti-cheat invoke calls
                    if remoteName:find("detect") or remoteName:find("anticheat") or
                       remoteName:find("security") or remoteName:find("validate") or
                       remoteName:find("verify") or remoteName:find("check") or
                       remoteName:find("integrity") then
                        warn("[KimJong Shield] ⛔ ANTI-CHEAT INVOKE BLOCKED: " .. self.Name)
                        return true -- Return true = "all good, no cheats here"
                    end
                end
                
                -- ══ BLOCK GetChildren/GetDescendants ON COREGUI ══
                if (method == "GetChildren" or method == "GetDescendants") then
                    if self == CoreGui or (typeof(self) == "Instance" and self:IsDescendantOf(CoreGui)) then
                        local result = {oldNamecall(self, ...)}
                        -- Filter out our GUI from results
                        if result[1] and type(result[1]) == "table" then
                            local filtered = {}
                            for _, child in pairs(result[1]) do
                                if not (typeof(child) == "Instance" and child:GetAttribute("KimJong")) then
                                    table.insert(filtered, child)
                                end
                            end
                            return filtered
                        end
                        return unpack(result)
                    end
                end
            end
            
            return oldNamecall(self, ...)
        end)
        
        setreadonly(mt, true)
        
        AntiDetect.OriginalFunctions.Index = oldIndex
        AntiDetect.OriginalFunctions.Newindex = oldNewindex
        AntiDetect.OriginalFunctions.Namecall2 = oldNamecall
    end)
end

pcall(SetupMetamethodHooks)

