-- 🛡️ LAYER 4: REMOTE SPY & BLOCKER
-- Monitor and block all anti-cheat remotes
-- ═══════════════════════════════════════

local function SetupRemoteBlocker()
    -- Scan existing remotes
    pcall(function()
        local blockedCount = 0
        
        local function ScanAndBlock(parent)
            for _, child in pairs(parent:GetDescendants()) do
                if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                    local name = child.Name:lower()
                    if name:find("anticheat") or name:find("anti_cheat") or 
                       name:find("detect") or name:find("exploit") or
                       name:find("security") or name:find("hack") or
                       name:find("violation") or name:find("report") or
                       name:find("flag") or name:find("monitor") or
                       name:find("integrity") or name:find("validate") or
                       name:find("ac_") or name:find("check_speed") or
                       name:find("speed_check") or name:find("fly_detect") or
                       name:find("noclip_detect") or name:find("tp_detect") then
                        AntiDetect.BlockedRemotes[child] = true
                        blockedCount = blockedCount + 1
                        
                        -- Disable the remote by intercepting
                        pcall(function()
                            if child:IsA("RemoteEvent") then
                                -- Create a fake connection that does nothing
                                child.OnClientEvent:Connect(function()
                                    return -- Eat the event
                                end)
                            end
                        end)
                    end
                end
            end
        end
        
        ScanAndBlock(ReplicatedStorage)
        ScanAndBlock(workspace)
        
        -- Also scan StarterPlayerScripts and StarterCharacterScripts
        pcall(function()
            ScanAndBlock(game:GetService("StarterPlayer"))
        end)
        
        if blockedCount > 0 then
            warn("[KimJong Shield] 🛡️ Blocked " .. blockedCount .. " anti-cheat remotes!")
        end
    end)
    
    -- Monitor new remotes being created
    pcall(function()
        AntiDetect.Connections.RemoteWatcher = ReplicatedStorage.DescendantAdded:Connect(function(child)
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                local name = child.Name:lower()
                if name:find("anticheat") or name:find("detect") or name:find("exploit") or
                   name:find("security") or name:find("hack") or name:find("ban") or
                   name:find("kick") or name:find("flag") or name:find("report") then
                    AntiDetect.BlockedRemotes[child] = true
                    warn("[KimJong Shield] 🛡️ New anti-cheat remote blocked: " .. child.Name)
                end
            end
        end)
    end)
end

pcall(SetupRemoteBlocker)

