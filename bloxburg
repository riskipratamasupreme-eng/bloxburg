local function SafeAntiDetect()
    -- Anti-AFK (works on ALL executors)
    pcall(function()
        local VU = game:GetService("VirtualUser")
        AddC("AntiAFK", LP.Idled:Connect(function()
            pcall(function()
                VU:CaptureController()
                VU:ClickButton2(Vector2.new())
            end)
        end))
    end)

    -- Property Guard (works on ALL executors)
    AddC("PropGuard", RunService.Heartbeat:Connect(function()
        pcall(function()
            local h = GetHum()
            if not h then return end
            if States.WalkSpeed > 16 and h.WalkSpeed ~= States.WalkSpeed then
                h.WalkSpeed = States.WalkSpeed
            end
            if States.JumpPower > 50 and h.JumpPower ~= States.JumpPower then
                h.UseJumpPower = true
                h.JumpPower = States.JumpPower
            end
            -- Rebuild fly if destroyed
            if States.Fly then
                local hrp = GetHRP()
                if hrp and not hrp:FindFirstChild("KJ_BG") then
                    local bg = Instance.new("BodyGyro")
                    bg.Name = "KJ_BG"; bg.MaxTorque = Vector3.new(9e9,9e9,9e9); bg.P = 9e4
                    bg.Parent = hrp
                end
                if hrp and not hrp:FindFirstChild("KJ_BV") then
                    local bv = Instance.new("BodyVelocity")
                    bv.Name = "KJ_BV"; bv.MaxForce = Vector3.new(9e9,9e9,9e9); bv.Velocity = Vector3.zero
                    bv.Parent = hrp
                end
            end
        end)
    end))

    -- OPTIONAL HOOKS (only if executor supports them)
    -- These are wrapped in pcall so they NEVER crash the script

    -- Anti-Kick hook
    pcall(function()
        if not hookfunction or not newcclosure then return end
        local old = hookfunction(LP.Kick, newcclosure(function(self, ...)
            if self == LP then return end
            return old(self, ...)
        end))
    end)

    -- Metamethod hooks
    pcall(function()
        if not getrawmetatable or not setreadonly or not newcclosure then return end
        local mt = getrawmetatable(game)
        if not mt then return end

        local oldNC = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            -- Block kicks
            if method == "Kick" and self == LP then return end
            -- Block anti-cheat remotes
            if method == "FireServer" and typeof(self) == "Instance" and self:IsA("RemoteEvent") then
                local n = self.Name:lower()
                if n:find("anticheat") or n:find("detect") or n:find("exploit") or
                   n:find("ban") or n:find("kick") or n:find("hack") or
                   n:find("security") or n:find("flag") or n:find("violation") or
                   n:find("ac_") or n:find("report") or n:find("monitor") then
                    return
                end
            end
            if method == "InvokeServer" and typeof(self) == "Instance" and self:IsA("RemoteFunction") then
                local n = self.Name:lower()
                if n:find("anticheat") or n:find("detect") or n:find("security") then
                    return true
                end
            end
            return oldNC(self, ...)
        end)
        setreadonly(mt, true)
    end)

    -- Block anti-cheat scripts
    pcall(function()
        local function killAC(parent)
            for _, d in pairs(parent:GetDescendants()) do
                if (d:IsA("LocalScript") or d:IsA("ModuleScript")) then
                    local n = d.Name:lower()
                    if n:find("anticheat") or n:find("anti_cheat") or n:find("ac_") or
                       n:find("cheatdetect") or n:find("exploitdetect") or n:find("hackdetect") or
                       n:find("guardian") or n:find("sentinel") or n:find("watchdog") then
                        pcall(function() d.Disabled = true end)
                    end
                end
            end
        end
        pcall(function() killAC(LP:FindFirstChild("PlayerScripts")) end)
        pcall(function() killAC(LP:FindFirstChild("PlayerGui")) end)
        pcall(function() killAC(LP.Character) end)
    end)
end

