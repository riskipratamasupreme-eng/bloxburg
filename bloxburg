-- ⚡ SAFE TELEPORT (Anti-Detect)
-- Teleports in small steps to avoid detection
local function SafeTeleport(targetCFrame, instant)
    pcall(function()
        local hrp = GetRootPart()
        if not hrp then return end
        
        if instant then
            hrp.CFrame = targetCFrame
            return
        end
        
        -- Gradual teleport (anti-detection)
        local startPos = hrp.CFrame.Position
        local endPos = targetCFrame.Position
        local distance = (endPos - startPos).Magnitude
        
        if distance < 200 then
            -- Short distance - instant is fine
            hrp.CFrame = targetCFrame
        else
            -- Long distance - break into steps
            local steps = math.min(math.ceil(distance / 100), 5)
            for i = 1, steps do
                local alpha = i / steps
                local midPoint = startPos:Lerp(endPos, alpha)
                hrp.CFrame = CFrame.new(midPoint)
                task.wait(0.05)
            end
            hrp.CFrame = targetCFrame
        end
    end)
end

