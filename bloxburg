local function Sli(p, t, mn, mx, def, cb, o)
    local v = def or mn
    local f = Instance.new("Frame", p)
    f.Size = UDim2.new(1, 0, 0, 36); f.BackgroundColor3 = Theme.BGAlt
    f.BorderSizePixel = 0; f.LayoutOrder = o or 0; f.ZIndex = 13
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)

    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(1, -50, 0, 14); l.Position = UDim2.new(0, 7, 0, 1)
    l.BackgroundTransparency = 1; l.Text = t; l.TextSize = 9
    l.Font = Enum.Font.Gotham; l.TextColor3 = Theme.Text
    l.TextXAlignment = Enum.TextXAlignment.Left; l.ZIndex = 14

    local vl = Instance.new("TextLabel", f)
    vl.Size = UDim2.new(0, 40, 0, 14); vl.Position = UDim2.new(1, -45, 0, 1)
    vl.BackgroundTransparency = 1; vl.Text = tostring(math.floor(v))
    vl.TextSize = 9; vl.Font = Enum.Font.GothamBold; vl.TextColor3 = Theme.Secondary
    vl.TextXAlignment = Enum.TextXAlignment.Right; vl.ZIndex = 14

    local sbg = Instance.new("Frame", f)
    sbg.Size = UDim2.new(1, -14, 0, 4); sbg.Position = UDim2.new(0, 7, 0, 24)
    sbg.BackgroundColor3 = Color3.fromRGB(40,40,40); sbg.BorderSizePixel = 0; sbg.ZIndex = 15
    Instance.new("UICorner", sbg).CornerRadius = UDim.new(1, 0)

    local pct = math.clamp((v-mn)/(mx-mn), 0, 1)
    local sf = Instance.new("Frame", sbg)
    sf.Size = UDim2.new(pct, 0, 1, 0); sf.BackgroundColor3 = Theme.Primary
    sf.BorderSizePixel = 0; sf.ZIndex = 16
    Instance.new("UICorner", sf).CornerRadius = UDim.new(1, 0)

    local kn = Instance.new("Frame", sbg)
    kn.Size = UDim2.new(0, 10, 0, 10); kn.Position = UDim2.new(pct, -5, 0.5, -5)
    kn.BackgroundColor3 = Color3.new(1,1,1); kn.BorderSizePixel = 0; kn.ZIndex = 17
    Instance.new("UICorner", kn).CornerRadius = UDim.new(1, 0)

    local sliding = false
    local function upd(pos)
        local r = math.clamp((pos.X - sbg.AbsolutePosition.X) / sbg.AbsoluteSize.X, 0, 1)
        v = math.floor(mn + (mx - mn) * r)
        vl.Text = tostring(v); sf.Size = UDim2.new(r, 0, 1, 0)
        kn.Position = UDim2.new(r, -5, 0.5, -5)
        pcall(cb, v)
    end
    sbg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true; upd(i.Position) end end)
    kn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true end end)
    UIS.InputChanged:Connect(function(i) if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then upd(i.Position) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)
end

local function Btn(p, t, cb, o)
