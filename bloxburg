CreateSection(ESPTab, "Player ESP", 1)

local function CreateESPForPlayer(player)
    if player == LocalPlayer then return end
    if ESPObjects[player.Name] then return end

    ESPObjects[player.Name] = {}
    local espData = ESPObjects[player.Name]

    -- Highlight
    task.spawn(function()
        while States.ChamsESP or States.PlayerESP do
            pcall(function()
                local char = player.Character
                if char then
                    if States.ChamsESP then
                        if not char:FindFirstChild("KJ_Highlight") then
                            local hl = Instance.new("Highlight")
                            hl.Name = "KJ_Highlight"
                            hl.FillColor = States.ESPColor
                            hl.OutlineColor = Color3.new(1, 1, 1)
                            hl.FillTransparency = 0.5
                            hl.OutlineTransparency = 0
                            hl.Parent = char
                            espData.Highlight = hl
                        end
                    end
                end
            end)
            task.wait(1)
            if not (States.ChamsESP or States.PlayerESP) then break end
        end
    end)
end

local function RemoveESPForPlayer(player)
    if ESPObjects[player.Name] then
        for _, obj in pairs(ESPObjects[player.Name]) do
            pcall(function()
                if typeof(obj) == "Instance" then obj:Destroy()
                else obj:Remove() end
            end)
        end
        ESPObjects[player.Name] = nil
    end
