local function GetChar()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function GetHum()
    local c = GetChar()
    return c and c:FindFirstChildOfClass("Humanoid")
end

local function GetHRP()
    local c = GetChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function AddConn(name, conn)
    if Connections[name] then
        pcall(function() Connections[name]:Disconnect() end)
    end
    Connections[name] = conn
end

local function RemConn(name)
    if Connections[name] then
        pcall(function() Connections[name]:Disconnect() end)
        Connections[name] = nil
    end
end

local function SafeTP(cf, stealth)
    pcall(function()
        local hrp = GetHRP()
        if not hrp then return end
        if stealth then
            local start = hrp.CFrame.Position
            local finish = cf.Position
            local dist = (finish - start).Magnitude
            if dist > 200 then
                local steps = math.min(math.ceil(dist / 100), 5)
                for i = 1, steps do
                    hrp.CFrame = CFrame.new(start:Lerp(finish, i / steps))
                    task.wait(0.05)
                end
            end
        end
        hrp.CFrame = cf
    end)
end

local function SafeSpeed(val)
    States.WalkSpeed = val
    _G.KimJongStates.WalkSpeed = val
    pcall(function()
        local h = GetHum()
        if h then h.WalkSpeed = val end
    end)
end

local function SafeJump(val)
    States.JumpPower = val
    _G.KimJongStates.JumpPower = val
    pcall(function()
        local h = GetHum()
        if h then h.UseJumpPower = true; h.JumpPower = val end
    end)
end

