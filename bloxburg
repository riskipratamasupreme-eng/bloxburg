_G.KimJongCleanup = function()
    pcall(function()
        CleanupAllConnections()
        CleanupDrawings()
        CleanupESP()

        local hum = GetHumanoid()
        if hum then
            hum.WalkSpeed = 16
            hum.JumpPower = 50
            hum.PlatformStand = false
        end

        local hrp = GetRootPart()
        if hrp then
            for _, child in pairs(hrp:GetChildren()) do
                if child.Name:sub(1, 3) == "KJ_" then
                    child:Destroy()
                end
            end
        end

        for _, p in pairs(Players:GetPlayers()) do
            pcall(function()
                if p.Character then
                    local hl = p.Character:FindFirstChild("KJ_Highlight")
                    if hl then hl:Destroy() end
                    if p.Character:FindFirstChild("Head") then
                        local bb = p.Character.Head:FindFirstChild("KJ_ESP_BB")
                        if bb then bb:Destroy() end
                    end
                end
            end)
        end

        ScreenGui:Destroy()
    end)
end

