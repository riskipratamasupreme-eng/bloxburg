-- Random name generator
local function RNG()
    local c = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
    local n = ""
    for i = 1, math.random(10, 18) do
        local r = math.random(1, #c)
        n = n .. c:sub(r, r)
    end
    return n
end

